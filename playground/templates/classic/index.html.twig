{% extends 'base.html.twig' %}

{% block title %}Classic Editor - CKEditor 5 Playground{% endblock %}

{% block body %}
<div class="mx-auto mt-12 px-4 max-w-5xl">
    <div class="mb-4">
        <a href="{{ path('app_index') }}" class="flex items-center gap-2 text-blue-600 hover:text-blue-800 text-sm hover:underline">
            &larr; Back to Home
        </a>
    </div>

    <h1 class="mt-4 mb-4 font-bold text-gray-800 text-2xl">Classic Editor</h1>

    <div class="flex gap-4 mb-6">
        <button
            type="button"
            onclick="window.triggerCKE5Error('base-classic')"
            class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-md text-white transition-colors">
            Trigger Error
        </button>
    </div>

    {{ cke5_editor('Hello World', id: 'base-classic') }}

    <h2 class="mt-12 mb-4 font-bold text-gray-800 text-xl">Minimal Preset</h2>

    {{ cke5_editor('Minimal preset', preset: 'minimal') }}

    <h2 class="mt-12 mb-4 font-bold text-gray-800 text-xl">Dynamic Preset</h2>

    {{ cke5_editor('Dynamic preset balloon editor', preset: preset) }}
</div>
{% endblock %}
